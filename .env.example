# Nexus Dash local configuration
# Copy this file to .env and fill only the values you use.
# .env and .env.local are intentionally ignored by git.

NEXUS_OPENAI_API_KEY=
NEXUS_ANTHROPIC_API_KEY=
NEXUS_GEMINI_API_KEY=
NEXUS_GOOGLE_CLIENT_ID=
NEXUS_GITHUB_PAT=
NEXUS_ALPHA_VANTAGE_API_KEY=

# Optional: override model IDs without editing js/ai.js.
NEXUS_OPENAI_MODEL=gpt-4o
NEXUS_ANTHROPIC_MODEL=claude-sonnet-4-6
NEXUS_GEMINI_MODEL=gemini-3.5-flash

# Optional: Spotify Client ID is public, but can be overridden for your own app.
NEXUS_SPOTIFY_CLIENT_ID=3ed94377fd3840f2b3f3e88967a2ed78
