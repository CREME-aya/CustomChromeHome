{
  "manifest_version": 3,
  "name": "Nexus Dash",
  "version": "1.0",
  "description": "時計、天気、ToDo、カレンダー、AI、Spotify、RSSをまとめた新しいタブ用ダッシュボードです",
  "key": "",
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "permissions": [
    "identity"
  ],
  "host_permissions": [
    "https://*/*",
    "<all_urls>"
  ]
}
