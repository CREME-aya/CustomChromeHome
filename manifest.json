{
  "manifest_version": 3,
  "name": "My Qiita Trend Tab",
  "version": "1.0",
  "description": "新しいタブをカスタマイズします",
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "permissions": [
    "storage",
    "geolocation",
    "identity"
  ],
  "host_permissions": [
    "https://*/*",
    "<all_urls>"
  ]
}